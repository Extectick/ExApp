{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://exapp.local/schemas/service-manifest.schema.json",
  "title": "ExApp Service Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifestVersion",
    "id",
    "name",
    "description",
    "version",
    "publisher",
    "category",
    "platform",
    "architecture",
    "apiVersion",
    "minAppVersion",
    "minAgentVersion",
    "entry",
    "permissions",
    "requiresAdmin",
    "dataPolicy"
  ],
  "properties": {
    "manifestVersion": { "const": 1 },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
    },
    "publisher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "category": { "type": "string", "minLength": 1 },
    "platform": { "enum": ["windows"] },
    "architecture": { "enum": ["x64", "x86", "arm64"] },
    "apiVersion": { "const": 1 },
    "minAppVersion": { "type": "string", "minLength": 1 },
    "minAgentVersion": { "type": "string", "minLength": 1 },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "executable", "arguments"],
      "properties": {
        "type": { "const": "process" },
        "executable": { "type": "string", "minLength": 1 },
        "arguments": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "ui": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "file"],
      "properties": {
        "type": { "const": "declarative" },
        "file": { "type": "string", "minLength": 1 }
      }
    },
    "permissions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "network",
          "background",
          "notifications",
          "filesystem.appData",
          "filesystem.downloads",
          "tun",
          "dns",
          "firewall",
          "routes",
          "admin"
        ]
      }
    },
    "requiresAdmin": { "type": "boolean" },
    "dataPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preserveOnUninstall"],
      "properties": {
        "preserveOnUninstall": { "type": "boolean" }
      }
    }
  }
}
