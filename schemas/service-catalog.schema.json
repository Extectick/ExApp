{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://exapp.local/schemas/service-catalog.schema.json",
  "title": "ExApp Service Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["catalogVersion", "channel", "updatedAt", "signature", "services"],
  "properties": {
    "catalogVersion": { "const": 1 },
    "channel": { "enum": ["stable", "beta", "dev"] },
    "updatedAt": { "type": "string", "format": "date-time" },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "keyId", "value"],
      "properties": {
        "algorithm": { "const": "dev-placeholder" },
        "keyId": { "type": "string", "minLength": 1 },
        "value": { "type": "string", "minLength": 1 }
      }
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "description",
          "version",
          "publisher",
          "category",
          "platform",
          "architecture",
          "status",
          "permissions"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "version": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
          },
          "publisher": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "name"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "name": { "type": "string", "minLength": 1 }
            }
          },
          "category": { "type": "string", "minLength": 1 },
          "platform": { "enum": ["windows"] },
          "architecture": { "enum": ["x64", "x86", "arm64"] },
          "status": { "enum": ["available", "planned", "hidden"] },
          "permissions": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "package": {
            "type": "object",
            "additionalProperties": false,
            "required": ["url", "sha256", "size"],
            "properties": {
              "url": { "type": "string", "minLength": 1 },
              "sha256": {
                "type": "string",
                "pattern": "^[a-fA-F0-9]{64}$"
              },
              "size": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    }
  }
}
