<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MyApp.Desktop.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="20">
            <TextBlock x:Name="TitleText" Style="{ThemeResource TitleTextBlockStyle}" Text="Settings" />
            <StackPanel Spacing="12">
                <TextBlock x:Name="ThemeTitleText" FontWeight="SemiBold" Text="Theme" />
                <RadioButtons x:Name="ThemeOptions" SelectionChanged="ThemeOptions_SelectionChanged">
                    <RadioButton x:Name="ThemeSystemOption" Content="Use system setting" Tag="System" />
                    <RadioButton x:Name="ThemeLightOption" Content="Light" Tag="Light" />
                    <RadioButton x:Name="ThemeDarkOption" Content="Dark" Tag="Dark" />
                </RadioButtons>
            </StackPanel>
            <StackPanel Spacing="12">
                <TextBlock x:Name="LanguageTitleText" FontWeight="SemiBold" Text="Language" />
                <ComboBox
                    x:Name="LanguageOptions"
                    MinWidth="240"
                    DisplayMemberPath="DisplayName"
                    SelectionChanged="LanguageOptions_SelectionChanged" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
