<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MyApp.Desktop.Pages.ServiceBrowserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" Padding="28" RowSpacing="20">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="860" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="CatalogSecondColumn.Width" Value="*" />
                        <Setter Target="VpnCard.(Grid.Row)" Value="0" />
                        <Setter Target="VpnCard.(Grid.Column)" Value="1" />
                        <Setter Target="VpnCard.Margin" Value="0" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="NarrowLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="16" />
                        <Setter Target="RootGrid.RowSpacing" Value="14" />
                        <Setter Target="CatalogSecondColumn.Width" Value="0" />
                        <Setter Target="VpnCard.(Grid.Row)" Value="1" />
                        <Setter Target="VpnCard.(Grid.Column)" Value="0" />
                        <Setter Target="VpnCard.Margin" Value="0,14,0,0" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock x:Name="TitleText" Style="{ThemeResource TitleTextBlockStyle}" Text="Service Browser" />
            <TextBlock x:Name="SubtitleText" Opacity="0.72" TextWrapping="Wrap" />
        </StackPanel>

        <InfoBar
            x:Name="OperationInfoBar"
            Grid.Row="1"
            IsClosable="True"
            IsOpen="False" />

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid x:Name="CatalogGrid" MaxWidth="760" ColumnSpacing="16" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition x:Name="CatalogSecondColumn" Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border
                    x:Name="MockCard"
                    MaxWidth="372"
                    Padding="18"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="3">
                                <TextBlock x:Name="MockNameText" FontSize="18" FontWeight="SemiBold" Text="Mock Service" />
                                <TextBlock x:Name="MockPublisherText" Opacity="0.68" />
                            </StackPanel>
                            <Border Grid.Column="1" Padding="9,4" Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}" CornerRadius="8">
                                <TextBlock x:Name="MockStateText" FontWeight="SemiBold" />
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="1" Spacing="12">
                            <TextBlock x:Name="MockDescriptionText" TextWrapping="Wrap" Opacity="0.82" />
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock x:Name="MockVersionText" Opacity="0.72" />
                                <TextBlock x:Name="MockCategoryText" Opacity="0.72" />
                            </StackPanel>
                        </StackPanel>

                        <Grid Grid.Row="2" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="MockDetailsButton" Click="MockDetailsButton_Click">
                                <TextBlock x:Name="MockDetailsButtonText" />
                            </Button>
                            <Button x:Name="MockActionButton" Grid.Column="1" Click="MockActionButton_Click" MinWidth="132">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ProgressRing x:Name="MockActionProgress" Width="16" Height="16" IsActive="False" Visibility="Collapsed" />
                                    <SymbolIcon x:Name="MockActionIcon" Symbol="Download" />
                                    <TextBlock x:Name="MockActionText" Text="Install" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <Border
                    x:Name="VpnCard"
                    Grid.Column="1"
                    MaxWidth="372"
                    Padding="18"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="VpnNameText" FontSize="18" FontWeight="SemiBold" Text="VPN Client" />
                        <TextBlock x:Name="VpnDescriptionText" Grid.Row="1" TextWrapping="Wrap" Opacity="0.82" />
                        <Button x:Name="VpnActionButton" Grid.Row="2" IsEnabled="False" HorizontalAlignment="Right" />
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
