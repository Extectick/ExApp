<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MyApp.Desktop.Pages.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="20">
            <TextBlock x:Name="TitleText" Style="{ThemeResource TitleTextBlockStyle}" Text="Diagnostics" />
            <InfoBar
                x:Name="ReadyInfo"
                IsOpen="True"
                Severity="Informational"
                Title="Diagnostics shell is ready"
                Message="Agent status, logs and diagnostic bundle export are planned for later MVPs." />
            <TextBlock x:Name="AppVersionText" Text="App version: 0.1.0-dev" />
            <TextBlock x:Name="AgentStatusText" Text="Agent: not connected" />
        </StackPanel>
    </ScrollViewer>
</Page>
