<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ExApp.Desktop.Pages.ServicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Padding="28" RowSpacing="20">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="760" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="DetailsActions.(Grid.Row)" Value="0" />
                        <Setter Target="DetailsActions.(Grid.Column)" Value="1" />
                        <Setter Target="DetailsActions.HorizontalAlignment" Value="Right" />
                        <Setter Target="DetailsActions.Margin" Value="0" />
                        <Setter Target="ServiceFilterBox.(Grid.Row)" Value="0" />
                        <Setter Target="ServiceFilterBox.(Grid.Column)" Value="1" />
                        <Setter Target="ServiceSearchBox.(Grid.ColumnSpan)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="NarrowLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="16" />
                        <Setter Target="RootGrid.RowSpacing" Value="14" />
                        <Setter Target="DetailsActions.(Grid.Row)" Value="1" />
                        <Setter Target="DetailsActions.(Grid.Column)" Value="0" />
                        <Setter Target="DetailsActions.HorizontalAlignment" Value="Left" />
                        <Setter Target="DetailsActions.Margin" Value="0,12,0,0" />
                        <Setter Target="ServiceFilterBox.(Grid.Row)" Value="1" />
                        <Setter Target="ServiceFilterBox.(Grid.Column)" Value="0" />
                        <Setter Target="ServiceSearchBox.(Grid.ColumnSpan)" Value="2" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TitleText" Style="{ThemeResource TitleTextBlockStyle}" Text="My services" />
            <Button x:Name="BackButton" Grid.Column="1" Click="BackButton_Click" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon Symbol="Back" />
                    <TextBlock x:Name="BackButtonText" Text="Back" />
                </StackPanel>
            </Button>
        </Grid>

        <InfoBar
            x:Name="ServiceOperationInfoBar"
            Grid.RowSpan="2"
            Canvas.ZIndex="10"
            MaxWidth="720"
            Margin="0,54,0,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            IsClosable="True"
            IsOpen="False" />

        <Grid x:Name="ListViewRoot" Grid.Row="1" RowSpacing="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="ServicesToolbar" ColumnSpacing="10" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <AutoSuggestBox
                    x:Name="ServiceSearchBox"
                    TextChanged="ServiceSearchBox_TextChanged">
                    <AutoSuggestBox.QueryIcon>
                        <SymbolIcon Symbol="Find" />
                    </AutoSuggestBox.QueryIcon>
                </AutoSuggestBox>
                <ComboBox
                    x:Name="ServiceFilterBox"
                    Grid.Column="1"
                    MinWidth="176"
                    SelectionChanged="ServiceFilterBox_SelectionChanged" />
            </Grid>

            <GridView
                x:Name="InstalledServicesGrid"
                Grid.Row="1"
                ItemsSource="{x:Bind Services}"
                IsItemClickEnabled="True"
                ItemClick="InstalledServicesGrid_ItemClick"
                SelectionMode="None"
                SizeChanged="InstalledServicesGrid_SizeChanged"
                Visibility="Collapsed"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid ItemWidth="456" Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                        <Setter Property="Margin" Value="0,0,14,14" />
                        <Setter Property="Padding" Value="0" />
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            MinHeight="200"
                            Padding="20"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid RowSpacing="18">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid ColumnSpacing="12" VerticalAlignment="Top">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Width="40"
                                        Height="40"
                                        Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                                        CornerRadius="8"
                                        Visibility="{Binding ServiceIconVisibility}">
                                        <Grid>
                                            <FontIcon
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="20"
                                                Glyph="{Binding ServiceIconGlyph}"
                                                Visibility="{Binding ServiceIconGlyphVisibility}" />
                                            <Image
                                                Width="28"
                                                Height="28"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Source="{Binding ServiceIconSource}"
                                                Stretch="Uniform"
                                                Visibility="{Binding ServiceIconImageVisibility}" />
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="10">
                                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding Name}" />
                                        <TextBlock
                                            MaxHeight="48"
                                            Opacity="0.72"
                                            Text="{Binding Message}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                                <Grid
                                    Grid.Row="1"
                                    ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Opacity="0.72"
                                            Text="{Binding VersionText}"
                                            TextTrimming="CharacterEllipsis"
                                            VerticalAlignment="Center" />
                                        <Button
                                            Grid.Column="1"
                                            Width="36"
                                            Height="34"
                                            Padding="0"
                                            AutomationProperties.Name="{Binding UpdateText}"
                                            Click="CardUpdateMenuItem_Click"
                                            IsEnabled="{Binding IsActionEnabled}"
                                            Tag="{Binding ServiceId}"
                                            ToolTipService.ToolTip="{Binding UpdateText}"
                                            Visibility="{Binding UpdateVisibility}">
                                            <SymbolIcon Symbol="Sync" />
                                        </Button>
                                    </Grid>
                                    <StackPanel
                                        Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                    <Button
                                        Width="148"
                                        Height="34"
                                        Padding="10,5"
                                        Click="ListToggleButton_Click"
                                        IsEnabled="{Binding IsActionEnabled}"
                                        Tag="{Binding ServiceId}">
                                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                            <Grid Width="22" Height="18">
                                                <ProgressRing
                                                    Width="16"
                                                    Height="16"
                                                    IsActive="{Binding IsBusy}"
                                                    Visibility="{Binding ProgressVisibility}" />
                                                <SymbolIcon
                                                    Symbol="{Binding ActionIcon}"
                                                    Visibility="{Binding IconVisibility}" />
                                            </Grid>
                                            <TextBlock Text="{Binding ActionText}" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        Width="36"
                                        Height="34"
                                        Padding="0"
                                        AutomationProperties.Name="{Binding ActionsText}"
                                        Click="CardMenuButton_Click"
                                        IsEnabled="{Binding IsActionEnabled}"
                                        Tag="{Binding ServiceId}"
                                        ToolTipService.ToolTip="{Binding ActionsText}">
                                        <SymbolIcon Symbol="More" />
                                        <Button.Flyout>
                                            <MenuFlyout Closed="CardMenuFlyout_Closed">
                                                <MenuFlyoutItem
                                                    Click="CardUninstallMenuItem_Click"
                                                    Tag="{Binding ServiceId}"
                                                    Text="{Binding UninstallText}">
                                                    <MenuFlyoutItem.Icon>
                                                        <SymbolIcon Symbol="Delete" />
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <StackPanel x:Name="ServicesLoadingPanel" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                <ProgressRing x:Name="ServicesLoadingRing" Width="32" Height="32" IsActive="True" />
                <TextBlock x:Name="ServicesLoadingText" Opacity="0.72" TextAlignment="Center" />
            </StackPanel>

            <StackPanel x:Name="EmptyServicesPanel" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                <FontIcon Glyph="&#xE71B;" FontSize="32" Opacity="0.65" />
                <TextBlock x:Name="EmptyServicesTitle" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock x:Name="EmptyServicesMessage" Opacity="0.72" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="460" />
            </StackPanel>
        </Grid>

        <Grid x:Name="DetailsViewRoot" Grid.Row="1" RowSpacing="16" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="DetailsServiceNameText" FontSize="24" FontWeight="SemiBold" Text="Mock Service" />
                            <TextBlock x:Name="DetailsServiceMessageText" Opacity="0.72" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>

                    <Grid ColumnSpacing="24" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="StatusLabelText" Opacity="0.72" Text="Status" />
                            <TextBlock x:Name="DetailsStateText" FontWeight="SemiBold" Text="stopped" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock x:Name="HealthLabelText" Opacity="0.72" Text="Health" />
                            <TextBlock x:Name="DetailsHealthText" FontWeight="SemiBold" Text="stopped" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="2">
                            <TextBlock x:Name="VersionLabelText" Opacity="0.72" Text="Version" />
                            <TextBlock x:Name="DetailsVersionText" FontWeight="SemiBold" Text="0.1.0" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Spacing="2">
                            <TextBlock x:Name="PreviousVersionLabelText" Opacity="0.72" />
                            <TextBlock x:Name="DetailsPreviousVersionText" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Spacing="2">
                            <TextBlock x:Name="ProcessIdLabelText" Opacity="0.72" />
                            <TextBlock x:Name="DetailsProcessIdText" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                            <TextBlock x:Name="UptimeLabelText" Opacity="0.72" />
                            <TextBlock x:Name="DetailsUptimeText" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Spacing="2">
                            <TextBlock x:Name="ExecutableLabelText" Opacity="0.72" />
                            <TextBlock
                                x:Name="DetailsExecutableText"
                                MaxWidth="480"
                                FontWeight="SemiBold"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel x:Name="DetailsActions" Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
                    <Button x:Name="DetailsToggleButton" Click="ToggleServiceButton_Click" MinWidth="148">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Grid Width="22" Height="18">
                                <ProgressRing x:Name="DetailsStartingRing" Width="16" Height="16" IsActive="False" Visibility="Collapsed" />
                                <SymbolIcon x:Name="DetailsToggleIcon" Symbol="Play" />
                            </Grid>
                            <TextBlock x:Name="DetailsToggleButtonText" Text="Start" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="RefreshButton" Click="RefreshButton_Click">
                        <SymbolIcon Symbol="Refresh" />
                    </Button>
                    <Button x:Name="ServiceMenuButton">
                        <SymbolIcon Symbol="More" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem x:Name="RestartMenuItem" Click="RestartMenuItem_Click">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Refresh" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="UpdateMenuItem" Click="UpdateMenuItem_Click">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Sync" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="UninstallMenuItem" Click="UninstallMenuItem_Click">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Delete" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock x:Name="LogsTitleText" FontSize="18" FontWeight="SemiBold" Text="Latest logs" />
                        <TextBlock x:Name="UpdatedText" Opacity="0.72" />
                    </StackPanel>
                    <VariableSizedWrapGrid
                        Grid.Row="1"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Right"
                        ItemHeight="34"
                        Orientation="Horizontal">
                        <TextBox
                            x:Name="LogsSearchBox"
                            Width="220"
                            Margin="0,0,8,0"
                            TextChanged="LogsSearchBox_TextChanged" />
                        <ToggleButton
                            x:Name="PauseLogsButton"
                            Margin="0,0,8,0"
                            Checked="PauseLogsButton_Changed"
                            Unchecked="PauseLogsButton_Changed" />
                        <Button
                            x:Name="FollowLogsButton"
                            Margin="0,0,8,0"
                            Click="FollowLogsButton_Click">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74B;" />
                        </Button>
                        <Button x:Name="ExportLogsButton" Margin="0,0,8,0" Click="ExportLogsButton_Click">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74E;" />
                        </Button>
                        <Button x:Name="RefreshLogsButton" Margin="0,0,8,0" Click="RefreshButton_Click">
                            <SymbolIcon Symbol="Refresh" />
                        </Button>
                        <Button x:Name="ClearLogsButton" Click="ClearLogsButton_Click">
                            <SymbolIcon Symbol="Delete" />
                        </Button>
                    </VariableSizedWrapGrid>
                    <TextBox
                        x:Name="LogsTextBox"
                        Grid.Row="2"
                        AcceptsReturn="True"
                        FontFamily="Consolas"
                        IsReadOnly="True"
                        MinHeight="140"
                        TextWrapping="NoWrap" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
