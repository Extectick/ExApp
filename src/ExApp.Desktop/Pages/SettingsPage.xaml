<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ExApp.Desktop.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="20">
            <TextBlock x:Name="TitleText" Style="{ThemeResource TitleTextBlockStyle}" Text="Settings" />
            <StackPanel Spacing="12">
                <TextBlock x:Name="ThemeTitleText" FontWeight="SemiBold" Text="Theme" />
                <RadioButtons x:Name="ThemeOptions" SelectionChanged="ThemeOptions_SelectionChanged">
                    <RadioButton x:Name="ThemeSystemOption" Content="Use system setting" Tag="System" />
                    <RadioButton x:Name="ThemeLightOption" Content="Light" Tag="Light" />
                    <RadioButton x:Name="ThemeDarkOption" Content="Dark" Tag="Dark" />
                </RadioButtons>
            </StackPanel>
            <StackPanel Spacing="12">
                <TextBlock x:Name="LanguageTitleText" FontWeight="SemiBold" Text="Language" />
                <ComboBox
                    x:Name="LanguageOptions"
                    MinWidth="240"
                    DisplayMemberPath="DisplayName"
                    SelectionChanged="LanguageOptions_SelectionChanged" />
            </StackPanel>
            <StackPanel Spacing="12">
                <TextBlock x:Name="UpdatesTitleText" FontWeight="SemiBold" />
                <TextBlock x:Name="VersionsText" Opacity="0.72" TextWrapping="Wrap" />
                <ToggleSwitch
                    x:Name="AutomaticUpdateChecksToggle"
                    Toggled="AutomaticUpdateChecksToggle_Toggled" />
                <ComboBox
                    x:Name="UpdateChannelOptions"
                    MinWidth="240"
                    SelectionChanged="UpdateChannelOptions_SelectionChanged">
                    <ComboBoxItem x:Name="StableChannelOption" Tag="stable" />
                    <ComboBoxItem x:Name="BetaChannelOption" Tag="beta" />
                </ComboBox>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button x:Name="CheckUpdatesButton" Click="CheckUpdatesButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Refresh" />
                            <TextBlock x:Name="CheckUpdatesButtonText" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="InstallUpdateButton" Click="InstallUpdateButton_Click" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Download" />
                            <TextBlock x:Name="InstallUpdateButtonText" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <ProgressBar
                    x:Name="UpdateProgress"
                    IsIndeterminate="True"
                    Visibility="Collapsed" />
                <InfoBar
                    x:Name="UpdateInfoBar"
                    IsClosable="True"
                    IsOpen="False" />
                <TextBlock x:Name="UpdateHistoryTitleText" FontWeight="SemiBold" />
                <TextBlock x:Name="UpdateHistoryText" Opacity="0.72" TextWrapping="Wrap" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
