<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ExApp.Desktop.Pages.ServiceBrowserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" Padding="28" RowSpacing="20">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="720" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="BrowserFilterBox.(Grid.Row)" Value="0" />
                        <Setter Target="BrowserFilterBox.(Grid.Column)" Value="1" />
                        <Setter Target="BrowserSearchBox.(Grid.ColumnSpan)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="NarrowLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="16" />
                        <Setter Target="RootGrid.RowSpacing" Value="14" />
                        <Setter Target="BrowserFilterBox.(Grid.Row)" Value="1" />
                        <Setter Target="BrowserFilterBox.(Grid.Column)" Value="0" />
                        <Setter Target="BrowserSearchBox.(Grid.ColumnSpan)" Value="2" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock x:Name="TitleText" Style="{ThemeResource TitleTextBlockStyle}" />
                <TextBlock x:Name="SubtitleText" Opacity="0.72" TextWrapping="Wrap" />
                <TextBlock x:Name="CatalogStatusText" FontSize="12" Opacity="0.62" TextWrapping="Wrap" />
            </StackPanel>
            <Button
                x:Name="RefreshCatalogButton"
                Grid.Column="1"
                Width="40"
                Height="40"
                Padding="0"
                Click="RefreshCatalogButton_Click">
                <Grid>
                    <SymbolIcon x:Name="RefreshCatalogIcon" Symbol="Refresh" />
                    <ProgressRing x:Name="RefreshCatalogRing" Width="18" Height="18" IsActive="False" Visibility="Collapsed" />
                </Grid>
            </Button>
        </Grid>

        <InfoBar
            x:Name="OperationInfoBar"
            Grid.RowSpan="2"
            Canvas.ZIndex="10"
            MaxWidth="720"
            Margin="0,54,0,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            IsClosable="True"
            IsOpen="False" />

        <Grid Grid.Row="1" RowSpacing="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="BrowserToolbar" ColumnSpacing="10" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <AutoSuggestBox
                    x:Name="BrowserSearchBox"
                    TextChanged="BrowserSearchBox_TextChanged">
                    <AutoSuggestBox.QueryIcon>
                        <SymbolIcon Symbol="Find" />
                    </AutoSuggestBox.QueryIcon>
                </AutoSuggestBox>
                <ComboBox
                    x:Name="BrowserFilterBox"
                    Grid.Column="1"
                    MinWidth="176"
                    SelectionChanged="BrowserFilterBox_SelectionChanged" />
            </Grid>

            <StackPanel x:Name="BrowserLoadingPanel" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                <ProgressRing x:Name="BrowserLoadingRing" Width="32" Height="32" IsActive="True" />
                <TextBlock x:Name="BrowserLoadingText" Opacity="0.72" TextAlignment="Center" />
            </StackPanel>

            <StackPanel x:Name="BrowserEmptyPanel" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6" Visibility="Collapsed">
                <FontIcon Glyph="&#xE71B;" FontSize="32" Opacity="0.65" />
                <TextBlock x:Name="BrowserEmptyTitle" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock x:Name="BrowserEmptyMessage" Opacity="0.72" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="460" />
            </StackPanel>

            <GridView
                x:Name="ServicesGrid"
                Grid.Row="1"
                ItemsSource="{x:Bind Services}"
                IsItemClickEnabled="False"
                IsMultiSelectCheckBoxEnabled="False"
                SelectionMode="None"
                SizeChanged="ServicesGrid_SizeChanged"
                VerticalAlignment="Stretch"
                VerticalContentAlignment="Top"
                Visibility="Collapsed"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid
                            ItemWidth="364"
                            MaximumRowsOrColumns="8"
                            Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                        <Setter Property="Margin" Value="0,0,14,14" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="MinHeight" Value="236" />
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            MinHeight="236"
                            Padding="18"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid RowSpacing="14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                            <Grid ColumnSpacing="12" VerticalAlignment="Top">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    Width="40"
                                    Height="40"
                                    Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                                    CornerRadius="8"
                                    Visibility="{Binding ServiceIconVisibility}">
                                    <Grid>
                                        <FontIcon
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="20"
                                            Glyph="{Binding ServiceIconGlyph}"
                                            Visibility="{Binding ServiceIconGlyphVisibility}" />
                                        <Image
                                            Width="28"
                                            Height="28"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Source="{Binding ServiceIconSource}"
                                            Stretch="Uniform"
                                            Visibility="{Binding ServiceIconImageVisibility}" />
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Text="{Binding Item.Name}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Opacity="0.68"
                                        Text="{Binding Item.Publisher.Name}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Border
                                    Grid.Column="2"
                                    Padding="9,4"
                                    Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                                    CornerRadius="8">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding StateText}" />
                                </Border>
                            </Grid>

                            <StackPanel Grid.Row="1" Spacing="12">
                                <TextBlock
                                    MaxHeight="60"
                                    Opacity="0.82"
                                    Text="{Binding Item.Description}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Opacity="0.72" Text="{Binding VersionText}" />
                                    <TextBlock
                                        MaxWidth="170"
                                        Opacity="0.72"
                                        Text="{Binding Item.Category}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </StackPanel>

                            <ProgressBar
                                Grid.Row="2"
                                Height="3"
                                IsIndeterminate="{Binding IsBusy}"
                                Visibility="{Binding ProgressVisibility}" />

                            <Grid Grid.Row="3" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button
                                    Click="DetailsButton_Click"
                                    IsEnabled="{Binding IsDetailsEnabled}"
                                    Tag="{Binding Item.Id}">
                                    <TextBlock Text="{Binding DetailsText}" />
                                </Button>
                                <Button
                                    Grid.Column="1"
                                    MinWidth="132"
                                    Click="ActionButton_Click"
                                    IsEnabled="{Binding IsActionEnabled}"
                                    Tag="{Binding Item.Id}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ProgressRing
                                            Width="16"
                                            Height="16"
                                            IsActive="{Binding IsBusy}"
                                            Visibility="{Binding ProgressVisibility}" />
                                        <SymbolIcon
                                            Symbol="{Binding ActionIcon}"
                                            Visibility="{Binding IconVisibility}" />
                                        <TextBlock Text="{Binding ActionText}" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>
    </Grid>
</Page>
